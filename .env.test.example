# Copy to .env.test to enable the tests that need a real S3 endpoint.
#
# The `export` prefixes are load-bearing: testutil.RequireS3 reads these with
# os.Getenv, so plain KEY=value would only set shell variables and every S3 test
# would silently skip — which looks exactly like a passing run.
export HAMSTOR_TEST_ENDPOINT=http://localhost:3900
export HAMSTOR_TEST_BUCKET=hamstor-test
export HAMSTOR_TEST_ACCESS_KEY_ID=test-access-key
export HAMSTOR_TEST_SECRET_ACCESS_KEY=test-secret-key
export HAMSTOR_TEST_REGION=garage
